generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

enum IssueSource {
  DISCORD
  GITHUB
}

enum IssueStatus {
  TRIAGE_PENDING
  TRIAGE_SPAM
  TRIAGE_PROMOTED
  BACKLOG
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
  CLOSED
}

enum Priority {
  NONE
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model Organization {
  id         String      @id @default(cuid())
  name       String
  slug       String      @unique
  avatarUrl  String?
  members    Member[]
  issues     Issue[]
  labels     Label[]
  milestones Milestone[]
  createdAt  DateTime    @default(now())
}

model Member {
  id          String          @id @default(cuid())
  orgId       String
  org         Organization    @relation(fields: [orgId], references: [id])
  name        String
  handle      String
  avatarUrl   String?
  role        String          @default("maintainer")
  notes       Note[]
  assignments IssueAssignee[]
}

model Label {
  id     String       @id @default(cuid())
  orgId  String
  org    Organization @relation(fields: [orgId], references: [id])
  name   String
  color  String
  issues IssueLabel[]
}

model Milestone {
  id      String       @id @default(cuid())
  orgId   String
  org     Organization @relation(fields: [orgId], references: [id])
  title   String
  dueDate DateTime?
  issues  Issue[]
}

model Issue {
  id          String      @id @default(cuid())
  number      Int
  title       String
  body        String      @db.Text
  source      IssueSource
  status      IssueStatus @default(TRIAGE_PENDING)
  priority    Priority    @default(NONE)
  orgId       String
  org         Organization    @relation(fields: [orgId], references: [id])
  assignees   IssueAssignee[]
  labels      IssueLabel[]
  milestoneId String?
  milestone   Milestone?  @relation(fields: [milestoneId], references: [id])

  // Discord metadata
  discordThreadId   String?
  discordAuthorId   String?
  discordAuthorName String?
  discordAvatarUrl  String?
  discordReplies    Json?   // array of {author, body, timestamp}

  // GitHub metadata (after promotion)
  githubIssueNumber Int?
  githubIssueUrl    String?
  linkedPRs         LinkedPR[]

  // AI deduplication
  similarityScore Float?
  duplicateOfId   String?
  duplicateOf     Issue?  @relation("Duplicates", fields: [duplicateOfId], references: [id])
  duplicates      Issue[] @relation("Duplicates")

  // Comms
  notes Note[]

  // Tracking
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  lastActivityAt DateTime @default(now())

  @@unique([orgId, number])
}

model LinkedPR {
  id       String @id @default(cuid())
  issueId  String
  issue    Issue  @relation(fields: [issueId], references: [id], onDelete: Cascade)
  prNumber Int
  prUrl    String
  ciStatus String // "success" | "failure" | "pending" | "running"
  title    String
}

model Note {
  id        String   @id @default(cuid())
  issueId   String
  issue     Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
  authorId  String
  author    Member   @relation(fields: [authorId], references: [id])
  body      String   @db.Text
  isPublic  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model IssueAssignee {
  issueId  String
  memberId String
  issue    Issue  @relation(fields: [issueId], references: [id], onDelete: Cascade)
  member   Member @relation(fields: [memberId], references: [id])

  @@id([issueId, memberId])
}

model IssueLabel {
  issueId String
  labelId String
  issue   Issue  @relation(fields: [issueId], references: [id], onDelete: Cascade)
  label   Label  @relation(fields: [labelId], references: [id])

  @@id([issueId, labelId])
}
